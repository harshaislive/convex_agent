BEFOREST_MODEL_PROVIDER=azure_ai

# Default OpenAI-compatible path
OPENAI_API_KEY=your_openai_api_key_here
BEFOREST_MODEL=openai:gpt-4.1-mini

# Azure AI Foundry OpenAI-compatible path
AZURE_AI_API_KEY=your_azure_ai_api_key_here
AZURE_AI_BASE_URL=https://azureuserbeforest.services.ai.azure.com/openai/v1/
AZURE_AI_MODEL=your_deployed_model_name

# Optional live-fetch timeout for beforest.co properties
BEFOREST_HTTP_TIMEOUT_SECONDS=10

# Optional ManyChat push settings
MANYCHAT_API_TOKEN=your_manychat_api_token_here
MANYCHAT_API_BASE_URL=https://api.manychat.com
MANYCHAT_CHANNEL=instagram

# Optional Convex persistence settings
# Current preview deployment HTTP action:
CONVEX_HTTP_ACTION_URL=https://knowing-raccoon-518.convex.site/instagram/store-dm-event
AGENT_SHARED_SECRET=replace_with_the_same_secret_used_in_convex
